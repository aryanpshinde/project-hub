<% if (success && success.length> 0) { %> <% for (let msg of success) { %>
    <div
      class="flex items-center p-4 mb-4 text-sm font-bold uppercase tracking-wide text-neo-ink bg-neo-success border-2 border-neo-ink shadow-neo-sm rounded-none"
      role="alert">
      <svg class="w-5 h-5 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
        fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"
          d="M5 13l4 4L19 7" />
      </svg>
      <div class="ms-3 flex-1">
        <%= msg %>
      </div>
      <button type="button"
        class="ms-auto bg-neo-surface border-2 border-neo-ink shadow-neo-sm inline-flex items-center justify-center h-8 w-8 shrink-0 rounded-none transition-all hover:bg-neo-warning active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
        onclick="this.parentElement.remove()" aria-label="Close">
        <span class="sr-only">Close</span>
        <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
          viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M6 18 17.94 6M18 18 6.06 6" />
        </svg>
      </button>
    </div>
    <% } %>
      <% } %>
        <% if (error && error.length> 0) { %> <% for (let msg of error) { %>
            <div
              class="flex items-center p-4 mb-4 text-sm font-bold uppercase tracking-wide text-neo-ink bg-neo-danger border-2 border-neo-ink shadow-neo-sm rounded-none"
              role="alert">
              <svg class="w-5 h-5 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"
                  d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <div class="ms-3 flex-1">
                <%= msg %>
              </div>
              <button type="button"
                class="ms-auto bg-neo-surface border-2 border-neo-ink shadow-neo-sm inline-flex items-center justify-center h-8 w-8 shrink-0 rounded-none transition-all hover:bg-neo-warning active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
                onclick="this.parentElement.remove()" aria-label="Close">
                <span class="sr-only">Close</span>
                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                  fill="none" viewBox="0 0 24 24">
                  <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M6 18 17.94 6M18 18 6.06 6" />
                </svg>
              </button>
            </div>
            <% } %>
              <% } %>