        </li>
        <% if (!currentUser) { %>
          <li class="border-b-2 border-neo-ink last:border-b-0 md:hidden">
            <a href="/login"
              class="block py-3 px-4 text-neo-ink hover:bg-neo-warning transition-colors rounded-none">Login</a>
          </li>
          <li class="border-b-2 border-neo-ink last:border-b-0 md:hidden">
            <a href="/register"
              class="block py-3 px-4 text-neo-ink hover:bg-neo-warning transition-colors rounded-none">Register</a>
