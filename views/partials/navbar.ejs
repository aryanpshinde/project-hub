                </button>
              </form>
            </li>
          </ul>
        </div>
        <% } else { %>
          <a href="/login"
            class="hidden sm:inline-flex items-center justify-center bg-neo-surface text-neo-ink border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-4 py-2 rounded-none transition-all hover:bg-neo-warning active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none">
