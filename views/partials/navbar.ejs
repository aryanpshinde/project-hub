        <li class="border-b-2 border-neo-ink last:border-b-0 md:border-b-0">
          <a href="/"
            class="block py-3 px-4 text-neo-ink hover:bg-neo-warning md:py-2 md:px-3 md:border-2 md:border-neo-ink md:bg-neo-primary md:text-white md:shadow-neo-sm md:hover:bg-neo-primary-hover md:active:translate-x-0.5 md:active:translate-y-0.5 md:active:shadow-neo-none transition-all rounded-none"
            aria-current="page">Home</a>
        </li>
        <li class="border-b-2 border-neo-ink last:border-b-0 md:border-b-0">
          <a href="/projects"
            class="block py-3 px-4 text-neo-ink hover:bg-neo-warning md:py-2 md:px-3 md:hover:bg-neo-warning transition-colors rounded-none">Projects</a>
        </li>
        <li class="border-b-2 border-neo-ink last:border-b-0 md:border-b-0">
          <a href="#"
            class="block py-3 px-4 text-neo-ink hover:bg-neo-warning md:py-2 md:px-3 md:hover:bg-neo-warning transition-colors rounded-none">About</a>
        </li>
        <li class="border-b-2 border-neo-ink last:border-b-0 md:border-b-0">
