            alt="user photo" />
        </button>

        <div class="z-50 hidden absolute mt-2 bg-neo-surface border-2 border-neo-ink shadow-neo w-48 rounded-none"
          id="user-dropdown">
          <div class="px-4 py-3 text-sm border-b-2 border-neo-ink bg-neo-bg">
            <span class="block text-neo-ink font-bold">
              <%= currentUser.username %>
            </span>
            <span class="block text-neo-ink-light truncate">
              <%= currentUser.email %>
            </span>
          </div>
          <ul class="p-2 text-sm text-neo-ink font-bold uppercase" aria-labelledby="user-menu-button">
            <li>
              <a href="/dashboard"
