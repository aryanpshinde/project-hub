<% layout('layouts/boilerplate') %>
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-4xl font-black uppercase tracking-tight text-neo-ink">My Projects</h1>
        <p class="text-neo-ink-light font-medium mt-2">Manage and track all your workspaces.</p>
      </div>
      <a href="/projects/new"
        class="inline-flex items-center justify-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-5 py-2.5 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none whitespace-nowrap">
        <svg class="w-4 h-4 me-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="square" stroke-width="3" d="M12 5v14m7-7H5" />
        </svg>
        New Project
      </a>
    </div>

    <form method="GET" action="/projects"
      class="mb-8 p-4 bg-neo-surface border-2 border-neo-ink shadow-neo-sm rounded-none grid grid-cols-1 md:grid-cols-5 gap-3 items-end">
      <div class="md:col-span-2">
        <label class="block mb-1 text-[10px] font-black uppercase text-neo-ink-light">Ownership</label>
        <select name="role"
          class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-2 py-1.5 shadow-neo-sm focus:outline-none rounded-none">
          <option value="">All Projects</option>
          <option value="owned" <%=query.role==='owned' ? 'selected' : '' %>>Owned by me</option>
          <option value="shared" <%=query.role==='shared' ? 'selected' : '' %>>Shared with me</option>
        </select>
      </div>
      <div class="md:col-span-2">
        <label class="block mb-1 text-[10px] font-black uppercase text-neo-ink-light">Status</label>
        <select name="status"
          class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-2 py-1.5 shadow-neo-sm focus:outline-none rounded-none">
          <option value="">All Statuses</option>
          <option value="active" <%=query.status==='active' ? 'selected' : '' %>>Active</option>
          <option value="completed" <%=query.status==='completed' ? 'selected' : '' %>>Completed</option>
          <option value="archived" <%=query.status==='archived' ? 'selected' : '' %>>Archived</option>
        </select>
      </div>
      <div class="md:col-span-1 flex gap-2">
        <button type="submit"
          class="flex-1 bg-neo-warning border-2 border-neo-ink text-[10px] font-black uppercase px-2 py-1.5 shadow-neo-sm hover:bg-yellow-300 active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none transition-all rounded-none">Filter</button>
        <a href="/projects"
          class="w-8 h-8 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-bg transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none rounded-none"
          title="Clear Filters">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="square" stroke-linejoin="square" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </a>
      </div>
    </form>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% if (projects.length> 0) { %>
        <% for (let p of projects) { %>
          <a href="/projects/<%= p._id %>"
            class="bg-neo-surface block p-6 border-2 border-neo-ink shadow-neo rounded-none transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-lg relative group min-w-0">

            <% if (p.status==='completed' ) { %>
              <span
                class="absolute top-4 right-4 inline-block bg-green-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Done</span>
              <% } else if (p.status==='archived' ) { %>
                <span
                  class="absolute top-4 right-4 inline-block bg-gray-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Archived</span>
                <% } else { %>
                  <span
                    class="absolute top-4 right-4 inline-block bg-neo-primary text-white border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Active</span>
                  <% } %>

                    <h5
                      class="mb-2 text-xl font-black uppercase tracking-tight text-neo-ink leading-none pr-20 truncate">
                      <%= p.title %>
                    </h5>
                    <p class="text-sm text-neo-ink-light font-medium mb-4 line-clamp-2 min-h-[2.5rem]">
                      <%= p.description || 'No description provided.' %>
                    </p>

                    <div
                      class="pt-4 border-t-2 border-dashed border-neo-ink/20 flex items-center justify-between text-[11px] font-bold uppercase text-neo-ink-light">
                      <div class="flex items-center gap-1.5 min-w-0">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="square" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        <span class="truncate">
                          <%= p.owner._id.equals(currentUser._id) ? 'You' : p.owner.username %>
                        </span>
                      </div>
                      <div class="flex items-center gap-1.5 shrink-0">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="square" stroke-width="2"
                            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        <span>
                          <%= p.members.length %> member<%= p.members.length !==1 ? 's' : '' %>
                        </span>
                      </div>
                    </div>
          </a>
          <% } %>
            <% } else { %>
              <div
                class="col-span-full text-center py-16 border-2 border-dashed border-neo-ink/20 rounded-none bg-neo-surface">
                <div
                  class="w-16 h-16 mx-auto mb-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm flex items-center justify-center">
                  <svg class="w-8 h-8 text-neo-ink-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="square" stroke-width="2"
                      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                  </svg>
                </div>
                <p class="text-sm font-bold uppercase text-neo-ink-light mb-4">No projects found matching your filters.
                </p>
                <a href="/projects"
                  class="inline-flex items-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-4 py-2 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none">
                  Clear Filters
                </a>
              </div>
              <% } %>
    </div>
  </div>