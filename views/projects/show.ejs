<% layout('layouts/boilerplate') %>
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <a href="/projects"
      class="inline-flex items-center text-sm font-bold uppercase tracking-wide text-neo-ink hover:text-neo-primary transition-colors mb-6">
      <svg class="w-4 h-4 me-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
        viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M5 12h14m-4-4-4 4m4 4-4-4" />
      </svg>
      Back to projects
    </a>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-1 space-y-6">
        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
          <div class="inline-block bg-neo-warning border-2 border-neo-ink shadow-neo-sm px-3 py-1 mb-4 rounded-none">
            <span class="text-xs font-black uppercase tracking-widest text-neo-ink">Project Details</span>
          </div>
          <div class="flex items-center gap-2 mb-3 flex-wrap">
            <h1 class="text-2xl font-black uppercase tracking-tight text-neo-ink leading-none">
              <%= project.title %>
            </h1>
            <% if (project.status==='completed' ) { %>
              <span
                class="inline-block bg-green-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Done</span>
              <% } else if (project.status==='archived' ) { %>
                <span
                  class="inline-block bg-gray-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Archived</span>
                <% } %>
          </div>
          <p class="mb-6 text-sm text-neo-ink-light font-medium leading-relaxed">
            <%= project.description || 'No description provided.' %>
          </p>
          <% if (project.owner._id.equals(currentUser._id)) { %>
            <div class="flex items-center gap-2 pt-4 border-t-2 border-dashed border-neo-ink/20">
              <a href="/projects/<%= project._id %>/edit"
                class="w-9 h-9 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-warning transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
                title="Edit Project">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-linejoin="square" stroke-width="2"
                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              </a>
              <form action="/projects/<%= project._id %>?_method=DELETE" method="POST"
                data-confirm="Delete this project?">
                <button type="submit"
                  class="w-9 h-9 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-red-200 text-red-600 hover:text-red-800 transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
                  title="Delete Project">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="square" stroke-linejoin="square" stroke-width="2"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </div>
            <% } %>
        </div>
        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
          <div class="inline-block bg-neo-primary border-2 border-neo-ink shadow-neo-sm px-3 py-1 mb-4 rounded-none">
            <span class="text-xs font-black uppercase tracking-widest text-white">Team</span>
          </div>
          <div class="space-y-3 mb-4">
            <div class="flex items-center gap-3 p-2 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
              <img class="w-8 h-8 border-2 border-neo-ink"
                src="https://ui-avatars.com/api/?name=<%= project.owner.username %>&background=2563eb&color=fff&bold=true"
                alt="owner">
              <div class="flex-1 min-w-0">
                <p class="font-bold text-neo-ink text-sm truncate">
                  <%= project.owner.username %>
                </p>
                <p class="text-[10px] font-bold uppercase text-neo-ink-light">Owner</p>
              </div>
            </div>
            <% if (project.members && project.members.length> 0) { %>
              <% for (let member of project.members) { %>
                <div class="flex items-center gap-3 p-2 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
                  <img class="w-8 h-8 border-2 border-neo-ink"
                    src="https://ui-avatars.com/api/?name=<%= member.username %>&background=525252&color=fff&bold=true"
                    alt="member">
                  <div class="flex-1 min-w-0">
                    <p class="font-bold text-neo-ink text-sm truncate">
                      <%= member.username %>
                    </p>
                    <p class="text-[10px] font-bold uppercase text-neo-ink-light">Member</p>
                  </div>
                  <% if (project.owner._id.equals(currentUser._id)) { %>
                    <form action="/projects/<%= project._id %>/members/<%= member._id %>?_method=DELETE" method="POST"
                      data-confirm="Remove this member?">
                      <button type="submit"
                        class="w-7 h-7 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-red-200 text-red-600 hover:text-red-800 transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
                        title="Remove member">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="square" stroke-linejoin="square" stroke-width="3"
                            d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      </button>
                    </form>
                    <% } %>
                </div>
                <% } %>
                  <% } %>
          </div>
          <% if (project.owner._id.equals(currentUser._id)) { %>
            <form action="/projects/<%= project._id %>/members" method="POST"
              class="flex gap-2 pt-4 border-t-2 border-dashed border-neo-ink/20">
              <input type="text" name="member[usernameOrEmail]" placeholder="Username/Email" required
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-3 py-2 shadow-neo-sm placeholder:text-neo-ink-light focus:outline-none focus:bg-neo-surface rounded-none transition-colors">
              <button type="submit"
                class="inline-flex items-center justify-center bg-neo-warning text-neo-ink border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-[10px] px-3 py-2 rounded-none transition-all hover:bg-yellow-300 active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none whitespace-nowrap">Add</button>
            </form>
            <% } %>
        </div>
      </div>
      <div class="lg:col-span-2">
        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none min-h-[500px]">
          <div class="flex items-center justify-between mb-6">
            <div class="inline-block bg-neo-success border-2 border-neo-ink shadow-neo-sm px-3 py-1 rounded-none">
              <span class="text-xs font-black uppercase tracking-widest text-neo-ink">Tasks</span>
            </div>
            <span class="text-xs font-bold uppercase text-neo-ink-light">
              <%= tasks ? tasks.length : 0 %> Total
            </span>
          </div>
          <form method="GET" action="/projects/<%= project._id %>"
            class="mb-6 p-4 bg-neo-bg border-2 border-dashed border-neo-ink/30 rounded-none grid grid-cols-2 md:grid-cols-5 gap-3 items-end">
            <div class="col-span-2 md:col-span-1">
              <label class="block mb-1 text-[10px] font-black uppercase text-neo-ink-light">Status</label>
              <select name="taskStatus"
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-2 py-1.5 shadow-neo-sm focus:outline-none rounded-none">
                <option value="">All</option>
                <option value="todo" <%=query.taskStatus==='todo' ? 'selected' : '' %>>Todo</option>
                <option value="in-progress" <%=query.taskStatus==='in-progress' ? 'selected' : '' %>>In Progress
                </option>
                <option value="done" <%=query.taskStatus==='done' ? 'selected' : '' %>>Done</option>
              </select>
            </div>
            <div class="col-span-2 md:col-span-1">
              <label class="block mb-1 text-[10px] font-black uppercase text-neo-ink-light">Priority</label>
              <select name="priority"
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-2 py-1.5 shadow-neo-sm focus:outline-none rounded-none">
                <option value="">All</option>
                <option value="high" <%=query.priority==='high' ? 'selected' : '' %>>High</option>
                <option value="medium" <%=query.priority==='medium' ? 'selected' : '' %>>Medium</option>
                <option value="low" <%=query.priority==='low' ? 'selected' : '' %>>Low</option>
              </select>
            </div>
            <div class="col-span-2 md:col-span-1">
              <label class="block mb-1 text-[10px] font-black uppercase text-neo-ink-light">Assignee</label>
              <select name="assignedTo"
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-2 py-1.5 shadow-neo-sm focus:outline-none rounded-none">
                <option value="">All</option>
                <option value="unassigned" <%=query.assignedTo==='unassigned' ? 'selected' : '' %>>Unassigned</option>
                <option value="<%= project.owner._id %>" <%=query.assignedTo===project.owner._id.toString() ? 'selected'
                  : '' %>><%= project.owner.username %>
                </option>
                <% if (project.members && project.members.length> 0) { %>
                  <% for (let member of project.members) { %>
                    <option value="<%= member._id %>" <%=query.assignedTo===member._id.toString() ? 'selected' : '' %>>
                      <%= member.username %>
                    </option>
                    <% } %>
                      <% } %>
              </select>
            </div>
            <div class="col-span-2 md:col-span-1">
              <label class="block mb-1 text-[10px] font-black uppercase text-neo-ink-light">Sort By</label>
              <select name="sort"
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-2 py-1.5 shadow-neo-sm focus:outline-none rounded-none">
                <option value="">Newest</option>
                <option value="dueDateAsc" <%=query.sort==='dueDateAsc' ? 'selected' : '' %>>Due Date (Asc)</option>
                <option value="dueDateDesc" <%=query.sort==='dueDateDesc' ? 'selected' : '' %>>Due Date (Desc)</option>
                <option value="priority" <%=query.sort==='priority' ? 'selected' : '' %>>Priority</option>
              </select>
            </div>
            <div class="col-span-2 md:col-span-1 flex gap-2">
              <button type="submit"
                class="flex-1 bg-neo-warning border-2 border-neo-ink text-[10px] font-black uppercase px-2 py-1.5 shadow-neo-sm hover:bg-yellow-300 active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none transition-all rounded-none">Filter</button>
              <a href="/projects/<%= project._id %>"
                class="w-8 h-8 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-bg transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none rounded-none"
                title="Clear Filters">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-linejoin="square" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </a>
            </div>
          </form>
          <form action="/projects/<%= project._id %>/tasks" method="POST"
            class="mb-6 p-4 bg-neo-bg border-2 border-dashed border-neo-ink/30 rounded-none grid grid-cols-1 md:grid-cols-2 gap-3">
            <div class="md:col-span-2">
              <input type="text" name="task[title]" placeholder="Task title..." required
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-2 shadow-neo-sm placeholder:text-neo-ink-light focus:outline-none focus:border-neo-primary rounded-none transition-colors">
            </div>
            <div>
              <select name="task[priority]"
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-2 shadow-neo-sm focus:outline-none focus:border-neo-primary rounded-none transition-colors">
                <option value="low">Low Priority</option>
                <option value="medium" selected>Medium Priority</option>
                <option value="high">High Priority</option>
              </select>
            </div>
            <div>
              <input type="date" name="task[dueDate]"
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-2 shadow-neo-sm focus:outline-none focus:border-neo-primary rounded-none transition-colors">
            </div>
            <div>
              <select name="task[assignedTo]"
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-2 shadow-neo-sm focus:outline-none focus:border-neo-primary rounded-none transition-colors">
                <option value="">Unassigned</option>
                <option value="<%= project.owner._id %>">
                  <%= project.owner.username %> (Owner)
                </option>
                <% if (project.members && project.members.length> 0) { %>
                  <% for (let member of project.members) { %>
                    <option value="<%= member._id %>">
                      <%= member.username %>
                    </option>
                    <% } %>
                      <% } %>
              </select>
            </div>
            <div class="flex items-center">
              <button type="submit"
                class="inline-flex items-center justify-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-5 py-2 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none w-full whitespace-nowrap">+
                Add Task</button>
            </div>
          </form>
          <div class="space-y-3">
            <% if (tasks && tasks.length> 0) { %>
              <% for (let task of tasks) { %>
                <div
                  class="p-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none hover:shadow-neo transition-shadow">
                  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <a href="/projects/<%= project._id %>/tasks/<%= task._id %>"
                          class="font-bold text-neo-ink hover:text-neo-primary transition-colors block truncate text-lg">
                          <%= task.title %>
                        </a>
                        <% if (task.status==='done' ) { %>
                          <span
                            class="inline-block bg-green-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Done</span>
                          <% } else if (task.status==='in-progress' ) { %>
                            <span
                              class="inline-block bg-neo-warning border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">In
                              Progress</span>
                            <% } else { %>
                              <span
                                class="inline-block bg-gray-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Todo</span>
                              <% } %>
                                <% if (task.priority==='high' ) { %>
                                  <span
                                    class="inline-block bg-red-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">High</span>
                                  <% } else if (task.priority==='medium' ) { %>
                                    <span
                                      class="inline-block bg-yellow-100 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Med</span>
                                    <% } %>
                      </div>
                      <div
                        class="flex items-center gap-3 text-[11px] font-bold uppercase text-neo-ink-light mt-1 flex-wrap">
                        <span>By <%= task.createdBy.username %></span>
                        <% if (task.dueDate) { %>
                          <span>Due: <%= new Date(task.dueDate).toLocaleDateString() %></span>
                          <% } %>
                            <% if (task.assignedTo) { %>
                              <span class="flex items-center gap-1">
                                <img
                                  src="https://ui-avatars.com/api/?name=<%= task.assignedTo.username %>&background=525252&color=fff&bold=true&size=16"
                                  class="border border-neo-ink" alt="">
                                <%= task.assignedTo.username %>
                              </span>
                              <% } else { %>
                                <span>Unassigned</span>
                                <% } %>
                      </div>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                      <% if (task.createdBy._id.equals(currentUser._id) || project.owner._id.equals(currentUser._id) ||
                        (task.assignedTo && task.assignedTo._id.equals(currentUser._id))) { %>
                        <form action="/projects/<%= project._id %>/tasks/<%= task._id %>/status?_method=PATCH"
                          method="POST">
                          <select name="task[status]" data-auto-submit
                            class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-[10px] font-bold uppercase px-2 py-1.5 shadow-neo-sm focus:outline-none rounded-none cursor-pointer h-8">
                            <option value="todo" <%=task.status==='todo' ? 'selected' : '' %>>Todo</option>
                            <option value="in-progress" <%=task.status==='in-progress' ? 'selected' : '' %>>Prog
                            </option>
                            <option value="done" <%=task.status==='done' ? 'selected' : '' %>>Done</option>
                          </select>
                        </form>
                        <a href="/projects/<%= project._id %>/tasks/<%= task._id %>/edit"
                          class="w-8 h-8 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-warning transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none rounded-none"
                          title="Edit Task">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="square" stroke-linejoin="square" stroke-width="2"
                              d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                          </svg>
                        </a>
                        <form action="/projects/<%= project._id %>/tasks/<%= task._id %>?_method=DELETE" method="POST"
                          data-confirm="Delete this task?">
                          <button type="submit"
                            class="w-8 h-8 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-red-200 text-red-600 hover:text-red-800 transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none rounded-none"
                            title="Delete Task">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="square" stroke-linejoin="square" stroke-width="2"
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                          </button>
                        </form>
                        <% } %>
                    </div>
                  </div>
                </div>
                <% } %>
                  <% } else { %>
                    <div class="text-center py-12 border-2 border-dashed border-neo-ink/20 rounded-none">
                      <p class="text-sm font-bold uppercase text-neo-ink-light">No tasks found matching your filters.
                      </p>
                      <a href="/projects/<%= project._id %>"
                        class="mt-2 inline-block text-xs font-bold uppercase text-neo-primary hover:underline">Clear
                        Filters</a>
                    </div>
                    <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>