<% layout('layouts/boilerplate') %>
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <a href="/projects"
      class="inline-flex items-center text-sm font-bold uppercase tracking-wide text-neo-ink hover:text-neo-primary transition-colors mb-6">
      <svg class="w-4 h-4 me-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
        viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M5 12h14m-4-4-4 4m4 4-4-4" />
      </svg>
      Back to projects
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <div class="lg:col-span-1 space-y-6">

        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
          <div class="inline-block bg-neo-warning border-2 border-neo-ink shadow-neo-sm px-3 py-1 mb-4 rounded-none">
            <span class="text-xs font-black uppercase tracking-widest text-neo-ink">Project Details</span>
          </div>
          <h1 class="mb-3 text-2xl font-black uppercase tracking-tight text-neo-ink leading-none">
            <%= project.title %>
          </h1>
          <p class="mb-6 text-sm text-neo-ink-light font-medium leading-relaxed">
            <%= project.description || 'No description provided.' %>
          </p>

          <% if (currentUser && project.owner._id.equals(currentUser._id)) { %>
            <div class="flex items-center gap-3 pt-4 border-t-2 border-dashed border-neo-ink/20">
              <a href="/projects/<%= project._id %>/edit"
                class="inline-flex items-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-4 py-2 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none">
                Edit
              </a>
              <form action="/projects/<%= project._id %>?_method=DELETE" method="POST"
                onsubmit="return confirm('Delete this project?');">
                <button type="submit"
                  class="inline-flex items-center bg-red-500 text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-4 py-2 rounded-none transition-all hover:bg-red-600 active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none">
                  Delete
                </button>
              </form>
            </div>
            <% } %>
        </div>

        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
          <div class="inline-block bg-neo-primary border-2 border-neo-ink shadow-neo-sm px-3 py-1 mb-4 rounded-none">
            <span class="text-xs font-black uppercase tracking-widest text-white">Team</span>
          </div>

          <div class="space-y-3 mb-4">
            <div class="flex items-center gap-3 p-2 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
              <img class="w-8 h-8 border-2 border-neo-ink"
                src="https://ui-avatars.com/api/?name=<%= project.owner.username %>&background=2563eb&color=fff&bold=true"
                alt="owner">
              <div class="flex-1 min-w-0">
                <p class="font-bold text-neo-ink text-sm truncate">
                  <%= project.owner.username %>
                </p>
                <p class="text-[10px] font-bold uppercase text-neo-ink-light">Owner</p>
              </div>
            </div>

            <% if (project.members && project.members.length> 0) { %>
              <% for (let member of project.members) { %>
                <div class="flex items-center gap-3 p-2 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
                  <img class="w-8 h-8 border-2 border-neo-ink"
                    src="https://ui-avatars.com/api/?name=<%= member.username %>&background=525252&color=fff&bold=true"
                    alt="member">
                  <div class="flex-1 min-w-0">
                    <p class="font-bold text-neo-ink text-sm truncate">
                      <%= member.username %>
                    </p>
                    <p class="text-[10px] font-bold uppercase text-neo-ink-light">Member</p>
                  </div>
                  <% if (currentUser && project.owner._id.equals(currentUser._id)) { %>
                    <form action="/projects/<%= project._id %>/members/<%= member._id %>?_method=DELETE" method="POST"
                      onsubmit="return confirm('Remove?');">
                      <button type="submit"
                        class="text-[10px] font-bold uppercase text-red-600 hover:text-red-800 transition-colors">
                        Remove
                      </button>
                    </form>
                    <% } %>
                </div>
                <% } %>
                  <% } %>
          </div>

          <% if (currentUser && project.owner._id.equals(currentUser._id)) { %>
            <form action="/projects/<%= project._id %>/members" method="POST"
              class="flex gap-2 pt-4 border-t-2 border-dashed border-neo-ink/20">
              <input type="text" name="usernameOrEmail" placeholder="Username/Email" required
                class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-xs font-medium block w-full px-3 py-2 shadow-neo-sm placeholder:text-neo-ink-light focus:outline-none focus:bg-white rounded-none transition-colors">
              <button type="submit"
                class="inline-flex items-center justify-center bg-neo-warning text-neo-ink border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-[10px] px-3 py-2 rounded-none transition-all hover:bg-yellow-300 active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none whitespace-nowrap">
                Add
              </button>
            </form>
            <% } %>
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none min-h-[500px]">
          <div class="flex items-center justify-between mb-6">
            <div class="inline-block bg-neo-success border-2 border-neo-ink shadow-neo-sm px-3 py-1 rounded-none">
              <span class="text-xs font-black uppercase tracking-widest text-neo-ink">Tasks</span>
            </div>
            <span class="text-xs font-bold uppercase text-neo-ink-light">
              <%= tasks ? tasks.length : 0 %> Total
            </span>
          </div>

          <form action="/projects/<%= project._id %>/tasks" method="POST"
            class="flex gap-3 mb-6 p-3 bg-neo-bg border-2 border-dashed border-neo-ink/30 rounded-none">
            <input type="text" name="task[title]" placeholder="What needs to be done?" required
              class="bg-white border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-2 shadow-neo-sm placeholder:text-neo-ink-light focus:outline-none focus:border-neo-primary rounded-none transition-colors">
            <button type="submit"
              class="inline-flex items-center justify-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-5 py-2 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none whitespace-nowrap">
              + Add
            </button>
          </form>

          <div class="space-y-3">
            <% if (tasks && tasks.length> 0) { %>
              <% for (let task of tasks) { %>
                <div
                  class="flex items-center justify-between p-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none hover:shadow-neo transition-shadow">
                  <div class="flex-1 min-w-0 mr-4">
                    <a href="/projects/<%= project._id %>/tasks/<%= task._id %>"
                      class="font-bold text-neo-ink hover:text-neo-primary transition-colors block truncate text-lg">
                      <%= task.title %>
                    </a>
                    <p class="text-[11px] font-bold uppercase text-neo-ink-light mt-1">
                      Created by <%= task.createdBy.username %>
                    </p>
                  </div>

                  <% if (currentUser && (task.createdBy._id.equals(currentUser._id) ||
                    project.owner._id.equals(currentUser._id))) { %>
                    <div class="flex gap-2 shrink-0">
                      <a href="/projects/<%= project._id %>/tasks/<%= task._id %>/edit"
                        class="text-xs font-bold uppercase text-neo-ink bg-neo-warning border-2 border-neo-ink px-3 py-1.5 shadow-neo-sm hover:bg-yellow-300 active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none transition-all rounded-none">
                        Edit
                      </a>
                      <form action="/projects/<%= project._id %>/tasks/<%= task._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Delete?');">
                        <button type="submit"
                          class="text-xs font-bold uppercase text-white bg-red-500 border-2 border-neo-ink px-3 py-1.5 shadow-neo-sm hover:bg-red-600 active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none transition-all rounded-none">
                          Del
                        </button>
                      </form>
                    </div>
                    <% } %>
                </div>
                <% } %>
                  <% } else { %>
                    <div class="text-center py-12 border-2 border-dashed border-neo-ink/20 rounded-none">
                      <p class="text-sm font-bold uppercase text-neo-ink-light">No tasks yet. Add one above to get
                        started!</p>
                    </div>
                    <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>