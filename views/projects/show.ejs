<%- layout('layouts/boilerplate') %>

<div class="max-w-screen-md mx-auto px-4 py-8">
  <div class="bg-neutral-primary-soft block max-w-sm p-6 border border-default rounded-base shadow-xs">
    <h5 class="mb-3 text-2xl font-semibold tracking-tight text-heading leading-8">
      <%= project.title %>
    </h5>
    <p class="text-body mb-6">
      <%= project.description || 'No description provided.' %>
    </p>

    <div class="flex items-center gap-3">
      <a
        href="/projects/<%= project._id %>/edit"
        class="inline-flex items-center text-white bg-brand box-border border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none"
      >
        Edit
      </a>

      <form action="/projects/<%= project._id %>?_method=DELETE" method="POST">
        <button
          type="submit"
          class="inline-flex items-center text-white bg-red-700 box-border border border-transparent hover:bg-red-800 focus:ring-4 focus:ring-red-300 shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none"
        >
          Delete
        </button>
      </form>
    </div>
  </div>
</div>
