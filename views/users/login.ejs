<% layout('layouts/boilerplate') %>

  <div class="max-w-md mx-auto px-4 py-12 md:py-16">
    <a href="/"
      class="inline-flex items-center text-sm font-bold uppercase tracking-wide text-neo-ink hover:text-neo-primary transition-colors mb-6">
      <svg class="w-4 h-4 me-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
        viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M5 12h14m-4-4-4 4m4 4-4-4" />
      </svg>
      Back to home
    </a>

    <div class="bg-neo-surface p-8 md:p-10 border-2 border-neo-ink shadow-neo rounded-none">
      <div class="inline-block bg-neo-warning border-2 border-neo-ink shadow-neo-sm px-3 py-1 mb-6 rounded-none">
        <span class="text-xs font-black uppercase tracking-widest text-neo-ink">Welcome Back</span>
      </div>

      <h1 class="mb-8 text-3xl md:text-4xl font-black uppercase tracking-tight text-neo-ink leading-none">
        Log In
      </h1>

      <form action="/login" method="post" class="space-y-6">
        <div>
          <label for="username"
            class="block mb-2 text-sm font-bold uppercase tracking-wide text-neo-ink">Username</label>
          <input type="text" id="username" name="username" autocomplete="username" autofocus
            class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-3 shadow-neo-sm placeholder:text-neo-ink-light focus:outline-none focus:bg-neo-surface rounded-none transition-colors"
            placeholder="johndoe" required />
        </div>

        <div>
          <label for="password"
            class="block mb-2 text-sm font-bold uppercase tracking-wide text-neo-ink">Password</label>
          <div class="relative">
            <input type="password" id="password" name="password" autocomplete="current-password"
              class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-3 pr-12 shadow-neo-sm placeholder:text-neo-ink-light focus:outline-none focus:bg-neo-surface rounded-none transition-colors"
              placeholder="••••••••" required />
            <button type="button" id="toggle-password"
              class="absolute inset-y-0 right-0 flex items-center px-3 text-neo-ink-light hover:text-neo-ink transition-colors"
              aria-label="Toggle password visibility">
              <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="square" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="square" stroke-width="2"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <svg id="eye-off-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="square" stroke-width="2"
                  d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
              </svg>
            </button>
          </div>
        </div>

        <div class="pt-4">
          <button type="submit"
            class="inline-flex items-center justify-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-sm px-6 py-3 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none w-full">
            Log In
            <svg class="w-4 h-4 ms-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
              fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M19 12H5m14 0-4 4m4-4-4-4" />
            </svg>
          </button>
        </div>
      </form>

      <div class="mt-8 pt-6 border-t-2 border-dashed border-neo-ink/20 text-center">
        <p class="text-sm font-medium text-neo-ink-light">
          Don't have an account?
          <a href="/register" class="font-bold text-neo-primary hover:underline underline-offset-4">Register here</a>
        </p>
      </div>
    </div>
  </div>

  <script src="/javascripts/password-toggle.js"></script>