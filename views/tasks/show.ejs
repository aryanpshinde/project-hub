<% layout('layouts/boilerplate') %>
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <a href="/projects/<%= task.project %>"
      class="inline-flex items-center text-sm font-bold uppercase tracking-wide text-neo-ink hover:text-neo-primary transition-colors mb-6">
      <svg class="w-4 h-4 me-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
        viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M5 12h14m-4-4-4 4m4 4-4-4" />
      </svg>
      Back to project
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-1 space-y-6">
        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
          <div class="inline-block bg-neo-primary border-2 border-neo-ink shadow-neo-sm px-3 py-1 mb-4 rounded-none">
            <span class="text-xs font-black uppercase tracking-widest text-white">Task Details</span>
          </div>

          <div class="flex items-center gap-2 mb-3 flex-wrap">
            <h1 class="text-2xl font-black uppercase tracking-tight text-neo-ink leading-none">
              <%= task.title %>
            </h1>
            <% if (task.status==='done' ) { %>
              <span
                class="inline-block bg-green-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Done</span>
              <% } else if (task.status==='in-progress' ) { %>
                <span
                  class="inline-block bg-neo-warning border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">In
                  Progress</span>
                <% } else { %>
                  <span
                    class="inline-block bg-gray-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Todo</span>
                  <% } %>
                    <% if (task.priority==='high' ) { %>
                      <span
                        class="inline-block bg-red-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">High</span>
                      <% } else if (task.priority==='medium' ) { %>
                        <span
                          class="inline-block bg-yellow-100 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Med</span>
                        <% } %>
          </div>

          <p class="mb-6 text-sm text-neo-ink-light font-medium leading-relaxed">
            <%= task.description || 'No description provided.' %>
          </p>

          <div class="space-y-3 mb-6">
            <div
              class="flex justify-between items-center p-3 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-neo-ink-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
                <p class="text-[10px] font-black uppercase text-neo-ink-light">Status</p>
              </div>
              <p class="text-xs font-bold text-neo-ink capitalize">
                <%= task.status.replace('-', ' ' ) %>
              </p>
            </div>

            <div
              class="flex justify-between items-center p-3 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-neo-ink-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-width="2"
                    d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
                </svg>
                <p class="text-[10px] font-black uppercase text-neo-ink-light">Priority</p>
              </div>
              <p class="text-xs font-bold text-neo-ink capitalize">
                <%= task.priority %>
              </p>
            </div>

            <div
              class="flex justify-between items-center p-3 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-neo-ink-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-[10px] font-black uppercase text-neo-ink-light">Due Date</p>
              </div>
              <p class="text-xs font-bold text-neo-ink">
                <%= task.dueDate ? new Date(task.dueDate).toLocaleDateString() : 'None' %>
              </p>
            </div>

            <div
              class="flex justify-between items-center p-3 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-neo-ink-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <p class="text-[10px] font-black uppercase text-neo-ink-light">Assignee</p>
              </div>
              <p class="text-xs font-bold text-neo-ink">
                <%= task.assignedTo ? task.assignedTo.username : 'Unassigned' %>
              </p>
            </div>

            <% if (task.completedAt) { %>
              <div
                class="flex justify-between items-center p-3 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-neo-ink-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="square" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <p class="text-[10px] font-black uppercase text-neo-ink-light">Completed</p>
                </div>
                <p class="text-xs font-bold text-neo-ink">
                  <%= new Date(task.completedAt).toLocaleDateString() %>
                </p>
              </div>
              <% } %>
          </div>

          <div
            class="pt-4 border-t-2 border-dashed border-neo-ink/20 text-xs font-bold uppercase tracking-wide text-neo-ink-light flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="square" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Created by: <span class="text-neo-ink">
              <%= task.createdBy.username %>
            </span>
          </div>

          <% if (task.createdBy._id.equals(currentUser._id) || project.owner._id.equals(currentUser._id) ||
            (task.assignedTo && task.assignedTo._id.equals(currentUser._id))) { %>
            <div class="flex items-center gap-2 pt-4 border-t-2 border-dashed border-neo-ink/20 mt-4">
              <a href="/projects/<%= project._id %>/tasks/<%= task._id %>/edit"
                class="w-9 h-9 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-warning transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
                title="Edit Task">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-linejoin="square" stroke-width="2"
                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              </a>
              <form action="/projects/<%= project._id %>/tasks/<%= task._id %>?_method=DELETE" method="POST"
                onsubmit="return confirm('Delete this task?');">
                <button type="submit"
                  class="w-9 h-9 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-red-200 text-red-600 hover:text-red-800 transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
                  title="Delete Task">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="square" stroke-linejoin="square" stroke-width="2"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </div>
            <% } %>
        </div>
      </div>

      <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none min-h-[500px] flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <div class="inline-block bg-neo-success border-2 border-neo-ink shadow-neo-sm px-3 py-1 rounded-none">
            <span class="text-xs font-black uppercase tracking-widest text-neo-ink">Discussion</span>
          </div>
          <span class="text-xs font-bold uppercase text-neo-ink-light">
            <%= comments ? comments.length : 0 %> Comments
          </span>
        </div>

        <div class="space-y-4 mb-6 flex-1">
          <% if (comments && comments.length> 0) { %>
            <% for (let comment of comments) { %>
              <div class="p-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none">
                <div class="flex justify-between items-start gap-3">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-2 flex-wrap">
                      <img class="w-6 h-6 border border-neo-ink"
                        src="https://ui-avatars.com/api/?name=<%= comment.author.username %>&background=525252&color=fff&bold=true&size=24"
                        alt="avatar">
                      <p class="text-xs font-bold text-neo-ink truncate">
                        <%= comment.author.username %>
                      </p>
                      <p class="text-[10px] font-bold uppercase text-neo-ink-light">
                        <%= new Date(comment.createdAt).toLocaleString() %>
                      </p>
                    </div>
                    <p class="text-sm text-neo-ink-light break-words">
                      <%= comment.body %>
                    </p>
                  </div>
                  <% if (comment.author._id.equals(currentUser._id) || project.owner._id.equals(currentUser._id)) { %>
                    <form
                      action="/projects/<%= project._id %>/tasks/<%= task._id %>/comments/<%= comment._id %>?_method=DELETE"
                      method="POST" onsubmit="return confirm('Delete this comment?');">
                      <button type="submit"
                        class="w-7 h-7 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-red-200 text-red-600 hover:text-red-800 transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none shrink-0"
                        title="Delete Comment">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="square" stroke-linejoin="square" stroke-width="3"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      </button>
                    </form>
                    <% } %>
                </div>
              </div>
              <% } %>
                <% } else { %>
                  <div
                    class="text-center py-12 border-2 border-dashed border-neo-ink/20 rounded-none flex-1 flex flex-col items-center justify-center">
                    <div
                      class="w-14 h-14 mx-auto mb-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm flex items-center justify-center">
                      <svg class="w-7 h-7 text-neo-ink-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="square" stroke-width="2"
                          d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.57 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                      </svg>
                    </div>
                    <p class="text-sm font-bold uppercase text-neo-ink-light">No comments yet. Start the discussion!</p>
                  </div>
                  <% } %>
        </div>

        <% if (project.owner._id.equals(currentUser._id) || project.members.some(m=> m._id.equals(currentUser._id))) {
          %>
          <form action="/projects/<%= project._id %>/tasks/<%= task._id %>/comments" method="POST"
            class="pt-4 border-t-2 border-dashed border-neo-ink/20">
            <label for="comment-body" class="block mb-2 text-xs font-bold uppercase tracking-wide text-neo-ink">Add a
              comment</label>
            <textarea id="comment-body" name="comment[body]" rows="3" required
              class="bg-neo-bg border-2 border-neo-ink text-neo-ink text-sm font-medium block w-full px-4 py-2 shadow-neo-sm placeholder:text-neo-ink-light focus:outline-none focus:bg-neo-surface rounded-none transition-colors resize-none"
              placeholder="What are your thoughts?"></textarea>
            <button type="submit"
              class="mt-3 inline-flex items-center justify-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-4 py-2 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none">
              Post Comment
            </button>
          </form>
          <% } %>
      </div>
    </div>
  </div>