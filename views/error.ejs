<% layout('layouts/boilerplate') %>

  <section class="flex items-center justify-center min-h-[70vh] p-4 w-full">
    <div
      class="w-full max-w-2xl bg-neo-surface p-8 md:p-12 text-center border-2 border-neo-ink shadow-neo rounded-none">
      <div class="inline-block bg-neo-danger border-2 border-neo-ink shadow-neo-sm px-4 py-1 mb-6 rounded-none">
        <span class="text-xs font-black uppercase tracking-widest text-neo-ink">System Error</span>
      </div>

      <h1 class="mb-4 text-8xl md:text-9xl font-black text-neo-ink leading-none">
        <%= err.statusCode %>
      </h1>

      <p class="mb-8 text-xl md:text-2xl font-bold text-neo-ink uppercase tracking-wide">
        <%= err.message %>
      </p>

      <% if (err.stack) { %>
        <div
          class="mt-6 mb-8 p-4 text-left overflow-x-auto bg-neo-bg border-2 border-neo-ink shadow-neo-sm w-full rounded-none">
          <pre class="text-xs md:text-sm text-neo-ink-light whitespace-pre-wrap break-all font-mono">
<%= err.stack %></pre>
        </div>
        <% } %>

          <a href="/projects"
            class="inline-flex items-center justify-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-sm px-6 py-3 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-1 active:translate-y-1 active:shadow-none">
            Back to projects
            <svg class="w-4 h-4 ms-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
              fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M19 12H5m14 0-4 4m4-4-4-4" />
            </svg>
          </a>
    </div>
  </section>