<% layout('layouts/boilerplate') %>
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-4xl font-black uppercase tracking-tight text-neo-ink">Dashboard</h1>
        <p class="text-neo-ink-light font-medium mt-2">Welcome back, <%= currentUser.username %>.</p>
      </div>
      <a href="/projects/new"
        class="inline-flex items-center justify-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-5 py-2.5 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none whitespace-nowrap">
        <svg class="w-4 h-4 me-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="square" stroke-width="3" d="M12 5v14m7-7H5" />
        </svg>
        New Project
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
      <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-black uppercase tracking-widest text-neo-ink-light mb-2">To Do</p>
            <p class="text-5xl font-black text-neo-ink leading-none">
              <%= taskCounts.todo %>
            </p>
          </div>
          <div class="w-14 h-14 bg-neo-bg border-2 border-neo-ink shadow-neo-sm flex items-center justify-center">
            <svg class="w-7 h-7 text-neo-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="square" stroke-width="3"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2">
              </path>
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-black uppercase tracking-widest text-neo-ink-light mb-2">In Progress</p>
            <p class="text-5xl font-black text-neo-ink leading-none">
              <%= taskCounts.inProgress %>
            </p>
          </div>
          <div class="w-14 h-14 bg-neo-warning border-2 border-neo-ink shadow-neo-sm flex items-center justify-center">
            <svg class="w-7 h-7 text-neo-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="square" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-black uppercase tracking-widest text-neo-ink-light mb-2">Completed</p>
            <p class="text-5xl font-black text-neo-ink leading-none">
              <%= taskCounts.done %>
            </p>
          </div>
          <div class="w-14 h-14 bg-green-200 border-2 border-neo-ink shadow-neo-sm flex items-center justify-center">
            <svg class="w-7 h-7 text-neo-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="square" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <% if (overdueTasks && overdueTasks.length> 0) { %>
      <div class="bg-neo-danger p-6 border-2 border-neo-ink shadow-neo rounded-none mb-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-red-500 border-2 border-neo-ink flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="square" stroke-width="3"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
              </path>
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-black uppercase tracking-tight text-neo-ink">Overdue Tasks</h2>
            <p class="text-xs font-bold text-neo-ink-light">You have <%= overdueTasks.length %> task<%=
                  overdueTasks.length> 1 ? 's' : '' %> past due date</p>
          </div>
        </div>
        <div class="space-y-3">
          <% for (let task of overdueTasks) { %>
            <div
              class="bg-neo-surface p-4 border-2 border-neo-ink shadow-neo-sm rounded-none flex items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <a href="/projects/<%= task.project._id %>/tasks/<%= task._id %>"
                  class="font-bold text-neo-ink hover:text-neo-primary transition-colors block truncate text-lg">
                  <%= task.title %>
                </a>
                <div class="flex items-center gap-3 text-[11px] font-bold uppercase text-neo-ink-light mt-1 flex-wrap">
                  <span>Project: <%= task.project.title %></span>
                  <span class="text-red-600">Due: <%= new Date(task.dueDate).toLocaleDateString() %></span>
                </div>
              </div>
              <a href="/projects/<%= task.project._id %>/tasks/<%= task._id %>/edit"
                class="w-9 h-9 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-warning transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none shrink-0"
                title="Edit Task">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-linejoin="square" stroke-width="2"
                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              </a>
            </div>
            <% } %>
        </div>
      </div>
      <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
            <div class="flex items-center justify-between mb-6">
              <div class="inline-block bg-neo-primary border-2 border-neo-ink shadow-neo-sm px-3 py-1 rounded-none">
                <span class="text-xs font-black uppercase tracking-widest text-white">My Projects</span>
              </div>
              <a href="/projects/new"
                class="w-9 h-9 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-warning transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none"
                title="New Project">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="square" stroke-width="3" d="M12 5v14m7-7H5" />
                </svg>
              </a>
            </div>
            <% if (ownedProjects && ownedProjects.length> 0) { %>
              <div class="space-y-3">
                <% for (let project of ownedProjects) { %>
                  <a href="/projects/<%= project._id %>"
                    class="block p-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-lg relative">
                    <% if (project.status==='completed' ) { %>
                      <span
                        class="absolute top-4 right-4 inline-block bg-green-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Done</span>
                      <% } else if (project.status==='archived' ) { %>
                        <span
                          class="absolute top-4 right-4 inline-block bg-gray-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Archived</span>
                        <% } %>
                          <h3 class="font-bold text-neo-ink text-lg mb-1 pr-16 truncate">
                            <%= project.title %>
                          </h3>
                          <p class="text-xs text-neo-ink-light mb-3 truncate">
                            <%= project.description || 'No description' %>
                          </p>
                          <div class="flex items-center gap-2 text-[10px] font-bold uppercase text-neo-ink-light">
                            <span>
                              <%= project.members.length %> member<%= project.members.length !==1 ? 's' : '' %>
                            </span>
                          </div>
                  </a>
                  <% } %>
              </div>
              <% } else { %>
                <div class="text-center py-12 border-2 border-dashed border-neo-ink/20 rounded-none">
                  <p class="text-sm font-bold uppercase text-neo-ink-light mb-4">You don't own any projects yet</p>
                  <a href="/projects/new"
                    class="inline-flex items-center bg-neo-primary text-white border-2 border-neo-ink shadow-neo-sm font-black uppercase tracking-wide text-xs px-4 py-2 rounded-none transition-all hover:bg-neo-primary-hover active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none">
                    Create Your First Project
                  </a>
                </div>
                <% } %>
          </div>

          <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none">
            <div class="inline-block bg-neo-success border-2 border-neo-ink shadow-neo-sm px-3 py-1 mb-6 rounded-none">
              <span class="text-xs font-black uppercase tracking-widest text-neo-ink">Team Projects</span>
            </div>
            <% if (memberProjects && memberProjects.length> 0) { %>
              <div class="space-y-3">
                <% for (let project of memberProjects) { %>
                  <a href="/projects/<%= project._id %>"
                    class="block p-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-lg relative">
                    <% if (project.status==='completed' ) { %>
                      <span
                        class="absolute top-4 right-4 inline-block bg-green-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Done</span>
                      <% } else if (project.status==='archived' ) { %>
                        <span
                          class="absolute top-4 right-4 inline-block bg-gray-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Archived</span>
                        <% } %>
                          <h3 class="font-bold text-neo-ink text-lg mb-1 pr-16 truncate">
                            <%= project.title %>
                          </h3>
                          <p class="text-xs text-neo-ink-light mb-3 truncate">
                            <%= project.description || 'No description' %>
                          </p>
                          <div class="flex items-center gap-2 text-[10px] font-bold uppercase text-neo-ink-light">
                            <span>Owner: <%= project.owner.username %></span>
                          </div>
                  </a>
                  <% } %>
              </div>
              <% } else { %>
                <div class="text-center py-12 border-2 border-dashed border-neo-ink/20 rounded-none">
                  <p class="text-sm font-bold uppercase text-neo-ink-light">You're not a member of any team projects yet
                  </p>
                </div>
                <% } %>
          </div>
        </div>

        <div class="bg-neo-surface p-6 border-2 border-neo-ink shadow-neo rounded-none mt-6">
          <div class="flex items-center justify-between mb-6">
            <div class="inline-block bg-neo-warning border-2 border-neo-ink shadow-neo-sm px-3 py-1 rounded-none">
              <span class="text-xs font-black uppercase tracking-widest text-neo-ink">All My Tasks</span>
            </div>
            <span class="text-xs font-bold uppercase text-neo-ink-light">
              <%= assignedTasks.length %> Total
            </span>
          </div>
          <% if (assignedTasks && assignedTasks.length> 0) { %>
            <div class="space-y-3">
              <% for (let task of assignedTasks) { %>
                <div
                  class="p-4 bg-neo-bg border-2 border-neo-ink shadow-neo-sm rounded-none hover:shadow-neo transition-shadow flex items-center justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      <a href="/projects/<%= task.project._id %>/tasks/<%= task._id %>"
                        class="font-bold text-neo-ink hover:text-neo-primary transition-colors block truncate text-base">
                        <%= task.title %>
                      </a>
                      <% if (task.status==='done' ) { %>
                        <span
                          class="inline-block bg-green-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Done</span>
                        <% } else if (task.status==='in-progress' ) { %>
                          <span
                            class="inline-block bg-neo-warning border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">In
                            Progress</span>
                          <% } else { %>
                            <span
                              class="inline-block bg-gray-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Todo</span>
                            <% } %>
                              <% if (task.priority==='high' ) { %>
                                <span
                                  class="inline-block bg-red-200 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">High</span>
                                <% } else if (task.priority==='medium' ) { %>
                                  <span
                                    class="inline-block bg-yellow-100 border border-neo-ink text-[10px] font-black uppercase px-2 py-0.5">Med</span>
                                  <% } %>
                    </div>
                    <div
                      class="flex items-center gap-3 text-[10px] font-bold uppercase text-neo-ink-light mt-1 flex-wrap">
                      <span>
                        <%= task.project.title %>
                      </span>
                      <% if (task.dueDate) { %>
                        <span>Due: <%= new Date(task.dueDate).toLocaleDateString() %></span>
                        <% } %>
                    </div>
                  </div>
                  <a href="/projects/<%= task.project._id %>/tasks/<%= task._id %>"
                    class="w-9 h-9 flex items-center justify-center border-2 border-neo-ink bg-neo-surface shadow-neo-sm hover:bg-neo-warning transition-all active:translate-x-0.5 active:translate-y-0.5 active:shadow-neo-none shrink-0"
                    title="View Task">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="square" stroke-width="3" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="square" stroke-width="3"
                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </a>
                </div>
                <% } %>
            </div>
            <% } else { %>
              <div class="text-center py-12 border-2 border-dashed border-neo-ink/20 rounded-none">
                <p class="text-sm font-bold uppercase text-neo-ink-light">No tasks assigned to you yet</p>
              </div>
              <% } %>
        </div>
  </div>